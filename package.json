    "deploy:testnet": "npx hardhat run scripts/deploy.js --network bsc_testnet"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0"
  }
}
